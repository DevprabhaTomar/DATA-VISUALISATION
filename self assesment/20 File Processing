try:
    file = open("sample.txt", "r")

    lines = file.readlines()

    words = 0
    chars = 0

    for line in lines:
        words += len(line.split())
        chars += len(line)

    print(len(lines))
    print(words)
    print(chars)

    file.close()

except FileNotFoundError:
    print("File not found")